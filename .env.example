# Market Lens — Example environment file
# Copy this file to .env and fill in values as needed.
# Credentials are stored encrypted in ~/.market-lens/credentials.json
# and managed via the Settings page — you do NOT need to put them here.

# Optional: override default log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: override auto-refresh interval in seconds (default 300)
AUTO_REFRESH_INTERVAL=300
